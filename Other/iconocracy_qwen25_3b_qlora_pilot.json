{
  "base_model": "Qwen/Qwen2.5-3B-Instruct",
  "dataset_path": "data/training/iconocracy_sft_v1_1.jsonl",
  "train_dataset_path": "data/training/iconocracy_sft_v1_1_train.jsonl",
  "val_dataset_path": "data/training/iconocracy_sft_v1_1_val.jsonl",
  "output_dir": "~/Models/iconocracy-qwen25-3b-sft-pilot-lora",
