  doi = {10.5749/culturalcritique.86.2014.0092},
  urldate = {2023-01-30},
  abstract = {Through a reading of Fassbinder's 1974 film Angst Essen Seele Auf, this article investigates historical developments in the neoliberalization of citizenship law. Reading this historical problematic through Fassbinder's own Brechtian depiction, the article explores how a critical aesthetics of melodrama and fantasy allegorize and illuminate this moment in citizenship's reconfiguration. Fassbinder's film exposes what I call the ``melotrauma'' of belonging to the neoliberal state, where preexisting legal paradigms of belonging---jus sanguinis, jus soli---are adjusted to suit globalizing capital's racially stratified orders of labor. The migrant worker's predicament, installed by poststate capital's legal apparatus, signals a uniquely exploitive form of lived alienation. Taking Fassbinder's case study of the West German context, this article examines how juridical reforms exploited decolonization and wartime population displacements to extort national prosperity from noncitizen migrant labor.},
  file = {/Users/anavanzin/Downloads/Bibliografias/Slater_2014_Jus Sanguinis, Jus Soli.pdf}
}

