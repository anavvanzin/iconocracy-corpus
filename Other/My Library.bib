@book{azevedoDicionarioAnalogicoLingua2019,
  title = {{Dicion\'ario anal\'ogico da l\'ingua portuguesa: ideias afins/ thesaurus}},
  shorttitle = {{Dicion\'ario anal\'ogico da l\'ingua portuguesa}},
  author = {Azevedo, Francisco Ferreira dos Santos},
  year = 2019,
  month = apr,
  publisher = {LEXIKON Editora},
  abstract = {Sabemos muito bem que o vocabul\'ario comum, adquirido e manejado no c\'irculo de amizades e de trabalho, n\~ao nos basta, em determinadas ocasi\~oes, para expressar exatamente o nosso pensamento. O contato com a gram\'atica e com os dicion\'arios \'e importante, mas temos necessidade de recorrer a outras fontes quando precisamos empregar palavras de uso comum para sermos perfeitamente compreendidos.Um dicion\'ario, no seu sentido mais corrente, \'e obra que objetiva documentar e fornecer os significados das palavras de uma l\'ingua, que constituem o l\'exico desta l\'ingua, apresentadas em ordem alfab\'etica. N\~ao pode, evidentemente, prescindir dele todo cidad\~ao que exercite, de algum modo, a linguagem verbal. J\'a um Dicion\'ario anal\'ogico tem finalidade distinta e complementar: n\~ao mais saber o que uma palavra significa, mas saber ``que palavras'' a ela se relacionam, analogicamente, atrav\'es de seus significados, em uma \'area sem\^antica em torno de uma ideia central afim.O Dicion\'ario anal\'ogico da l\'ingua portuguesa -- ideias afins \'e um dicion\'ario tem\'atico, isto \'e, as entradas s\~ao organizadas por temas (como semelhan\c ca, pureza e converg\^encia) e n\~ao como uma lista alfab\'etica de palavras. Dois tipos de busca s\~ao poss\'iveis para achar uma palavra espec\'ifica: \'e poss\'ivel buscar o tema ao qual est\'a relacionada ou recorrer ao \'indice, com mais de 100 mil entradas (palavras e express\~oes diferentes), estas sim, em ordem alfab\'etica, enviando a quase 160 mil refer\^encias diferentes ao longo do dicion\'ario, uma cole\c c\~ao de conceitos de grande import\^ancia e valor para quem escreve por gosto ou por of\'icio. Uma ferramenta essencial para escritores, advogados, jornalistas, m\'usicos, poetas etc.},
  googlebooks = {aMWSDwAAQBAJ},
  isbn = {978-85-8300-117-1},
  langid = {portuguese},
  keywords = {Language Arts & Disciplines / Linguistics / General,Reference / Dictionaries,Reference / Thesauri},
  file = {/Users/ana/Zotero/storage/AGZJ74G8/Azevedo_2019_Dicionário analógico da língua portuguesa.pdf}
}

