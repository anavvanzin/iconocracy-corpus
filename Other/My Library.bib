@article{brantFormacaoCostumeInternacional2017,
  title = {{A forma\c c\~ao do costume internacional na atualidade}},
  author = {Brant, Leonardo Nemer Caldeira and Biazatti, Bruno de Oliveira},
  year = 2017,
  journal = {Revista da Escola Superior da Magistratura do Estado do Cear\'a},
  volume = {15},
  number = {1},
  pages = {125--169},
  abstract = {O costume, a fonte mais antiga do direito internacional, se forma a partir de dois elementos cumulativos: a pr\'atica estatal, que constitui o seu elemento objetivo, e a opinio juris, seu componente subjetivo. Esses dois elementos se adaptaram a pr\'opria evolu\c c\~ao das condi\c c\~oes pol\'iticas e sociais da sociedade internacional, tornando o costume uma fonte male\'avel, capaz de acompanhar as mudan\c cas de paradigma do direito internacional. Diante disso, n\~ao se pode negar que as normas consuetudin\'arias se formam, hoje, em um cen\'ario muito diferente daquele identiic\'avel em meados do s\'eculo passado, sendo necess\'ario realizar o estudo do costume conforme essas novas condi\c c\~oes. Seguindo essa metodologia, o presente trabalho se dedica ao estudo da forma\c c\~ao das normas consuetudin\'arias \`a luz do atual status quo, de forma a apontar as particularidades do direito internacional contempor\^aneo e seus impactos no costume.},
  langid = {portuguese},
  keywords = {direito-internacional},
  file = {/Users/ana/Zotero/storage/3MLALQDZ/Brant_Biazatti_2017_A formação do costume internacional na atualidade.pdf;/Users/ana/Zotero/storage/PQGQKP22/Brant_Biazatti_2017_A formação do costume internacional na atualidade.pdf}
