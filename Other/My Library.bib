@article{howardComparativeCitizenshipAgenda2006,
  title = {Comparative {{Citizenship}}: {{An Agenda}} for {{Cross-National Research}}},
  shorttitle = {Comparative {{Citizenship}}},
  author = {Howard, Marc Morj{\'e}},
  year = 2006,
  journal = {Perspectives on Politics},
  volume = {4},
  number = {3},
  eprint = {20446201},
  eprinttype = {jstor},
  pages = {443--455},
  publisher = {[American Political Science Association, Cambridge University Press]},
  issn = {1537-5927},
  urldate = {2023-01-30},
  abstract = {In this article, I attempt to integrate the study of citizenship into debates in comparative politics, in two different ways. First, I justify the real-world importance of the topic, and thereby encourage other scholars to grapple with its manifestations and implications. Second, I present some suggestive evidence, based on the 15 "older" countries of the European Union (EU). The findings not only illustrate the extent of cross-national variation in citizenship policies at two different time periods, but they help to demonstrate the applicability of comparative analysis to categorizing and explaining both long-lasting cross-national differences and more recent change in some countries. In explaining the historical variation within the EU, I consider whether or not a country had a prior experience as a colonial power, as well as whether it became a democracy in the nineteenth century. In accounting for continuity or change over the last few decades, I argue that while various international and domestic pressures have led to liberalization in a number of countries, these usually occurred in the absence of public discussion and involvement. In contrast, when public opinion gets mobilized and engaged on issues related to citizenship reform--usually by a well-organized far right party, but also sometimes by a referendum or petition campaign--liberalization is usually blocked, or further restrictions are introduced. This finding raises important, paradoxical, and troubling questions about the connection between democratic processes and liberal outcomes.},
  file = {/Users/anavanzin/Downloads/Bibliografias/Howard_2006_Comparative Citizenship.pdf}
}

@article{hoxhaALLERADICIDELLAFFILIAZIONE2021,
  title = {{{ALLE RADICI DELL}}'{{AFFILIAZIONE}}. {{L}}'{{EMERSIONE DELLE PRATICHE PARAADOTTIVE NEL CODICE CIVILE DEL}} 1942. ({{Italian}}): {{At}} the Roots of Affiliation. {{The}} Emersion of Para-Adoptive Practices in the Civil Code of 1942. ({{English}})},
  shorttitle = {{{ALLE RADICI DELL}}'{{AFFILIAZIONE}}. {{L}}'{{EMERSIONE DELLE PRATICHE PARAADOTTIVE NEL CODICE CIVILE DEL}} 1942. ({{Italian}})},
  author = {Hoxha, Damigela},
  year = 2021,
  month = jan,
  journal = {Archivio Giuridico},
  number = {1},
  pages = {127--153},
  issn = {03915646},
  urldate = {2023-01-31},
  abstract = {The essay investigates the introduction in the Civil code of the institution of affiliation as an expression of the European phenomenon of the so-called customary 'para-adoptive' practices, from the Middle Ages to the Ancient Regime, intended to perform a wide range of functions through the factual reproduction of a parental bond. The need for an institution that, without demanding all the requirements for the adoption and without achieving all the effects, would govern these 'almost familiar' situations became even more urgent following the catastrophic events at the turn of the 19th century and the beginning of the 20th century. The high number of orphans due to earthquakes or wars, and of 'foundlings' welcomed and raised in families highlighted the unfortunate need to overcome the boundaries of the adoptive institution, as outlined by the 1865 Code, for welfare purposes and to provide juridical protection to these 'chosen children'. (English)},
  keywords = {affiliation,affiliazione,history of adoption,history of family law,storia del diritto di famiglia,storia dell'adozione},
  file = {/Users/anavanzin/Downloads/Bibliografias/Hoxha_2021_ALLE RADICI DELL'AFFILIAZIONE.pdf}
}

@article{huddlestonNationalityPoliciesBooks2020,
  title = {Nationality {{Policies}} in the {{Books}} and in {{Practice}}: {{Comparing Immigrant Naturalisation}} across {{Europe}}},
  shorttitle = {Nationality {{Policies}} in the {{Books}} and in {{Practice}}},
  author = {Huddleston, Thomas and Falcke, Swantje},
  year = 2020,
  journal = {International Migration},
  volume = {58},
  number = {2},
  pages = {255--271},
  issn = {1468-2435},
  doi = {10.1111/imig.12656},
  urldate = {2023-07-07},
  abstract = {This article explores whether differences in the implementation of nationality laws explain gaps between nationality laws and nationality acquisition across Europe. Previous research confirms that nationality acquisition among the foreign-born in Western European countries is largely determined by the inclusiveness of nationality policies and the characteristics of the immigrant population. Drawing on recent data on nationality procedures across Europe, this article argues that, regardless of the nationality laws in place, nationality procedures create major obstacles for different types of immigrants. This article uses data from the European Social Survey to conduct multi-level analysis of nationality acquisition in 17 European countries among long-settled foreign-born adult arrivals, controlling for their individual, origin and destination country characteristics. The analysis finds that nationality procedures are as important as nationality laws for nationality acquisition among most immigrants living in Europe today, especially for immigrants who are most likely to benefit and apply: immigrants from developing countries.},
  langid = {english},
  file = {/Users/anavanzin/Downloads/Bibliografias/Huddleston_Falcke_2020_Nationality Policies in the Books and in Practice.epub;/Users/anavanzin/Downloads/Bibliografias/Huddleston_Falcke_2020_Nationality Policies in the Books and in Practice.pdf;/Users/anavanzin/Downloads/Bibliografias/Huddleston_Falcke_2020_Nationality Policies in the Books and in Practice10.pdf;/Users/anavanzin/Downloads/Bibliografias/Huddleston_Falcke_2020_Nationality Policies in the Books and in Practice11.pdf;/Users/anavanzin/Downloads/Bibliografias/Huddleston_Falcke_2020_Nationality Policies in the Books and in Practice12.pdf;/Users/anavanzin/Downloads/Bibliografias/Huddleston_Falcke_2020_Nationality Policies in the Books and in Practice2.epub;/Users/anavanzin/Downloads/Bibliografias/Huddleston_Falcke_2020_Nationality Policies in the Books and in Practice2.pdf;/Users/anavanzin/Downloads/Bibliografias/Huddleston_Falcke_2020_Nationality Policies in the Books and in Practice3.epub;/Users/anavanzin/Downloads/Bibliografias/Huddleston_Falcke_2020_Nationality Policies in the Books and in Practice3.pdf;/Users/anavanzin/Downloads/Bibliografias/Huddleston_Falcke_2020_Nationality Policies in the Books and in Practice4.pdf;/Users/anavanzin/Downloads/Bibliografias/Huddleston_Falcke_2020_Nationality Policies in the Books and in Practice5.pdf;/Users/anavanzin/Downloads/Bibliografias/Huddleston_Falcke_2020_Nationality Policies in the Books and in Practice6.pdf;/Users/anavanzin/Downloads/Bibliografias/Huddleston_Falcke_2020_Nationality Policies in the Books and in Practice7.pdf;/Users/anavanzin/Downloads/Bibliografias/Huddleston_Falcke_2020_Nationality Policies in the Books and in Practice8.pdf;/Users/anavanzin/Downloads/Bibliografias/Huddleston_Falcke_2020_Nationality Policies in the Books and in Practice9.pdf;/Users/ana/Zotero/storage/VZPSIRWW/imig.html}
