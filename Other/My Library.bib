  issn = {0104-9313, 1678-4944},
  doi = {10.1590/S0104-93132012000300003},
  urldate = {2025-12-06},
  abstract = {Os s\'imbolos da Rep\'ublica, constitu\'ida no Brasil em 1889, n\~ao indicam uma ruptura radical com o regime mon\'arquico anterior, como foi o caso na Fran\c ca. As cores da bandeira imperial remetiam \`as cores din\'asticas. Na Rep\'ublica, sua estrutura foi mantida, sendo acrescentado o lema "Ordem e Progresso", o que atestava que os positivistas haviam conseguido impor sua interpreta\c c\~ao do novo regime. Quanto ao Hino Nacional, a Rep\'ublica n\~ao havia conseguido infundir uma nova vers\~ao, o povo tendo manifestado sua predile\c c\~ao pelo hino imperial. Quanto \`a alegoria da Rep\'ublica, havia tentativas de represent\'a-la por figuras femininas, demasiado pr\'oximas, no entanto, da Marianne francesa. A figura de Tiradentes tinha uma resson\^ancia mais dur\'avel, porque permitia ligar v\'arias dimens\~oes da na\c c\~ao: a aboli\c c\~ao da escravatura e a independ\^encia.},
  langid = {portuguese},
  keywords = {Alegoria da Republica,Alemanha,Brasil),Identidade nacional,Nacionalismo de Estado,Simbolos nacionais (Franca,Tiradentes},
  file = {/Users/ana/Zotero/storage/U3HEPEP2/Jurt - 2012 - O Brasil um Estado-nação a ser contruído. O papel dos símbolos nacionais, do Império à República.pdf}
}

