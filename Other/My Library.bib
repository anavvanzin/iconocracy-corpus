@article{IllegitimateBordersJus2023,
  title = {Illegitimate {{Borders}}: "{{Jus Sanguinis}}" {{Citizenship}} and the {{Legal Construction}} of {{Family}}, {{Race}}, and {{Nation}}},
  year = 2023,
  abstract = {The citizenship status of children born to American parents outside the United States governed by a complex set of statutes. When the parents of such children are not married, these st encumber the transmission of citizenship between father and child while readily recognizing the c an American mother as a citizen. Much of the debate concerning the propriety and constitutional those laws has centered on the extent to which they reflect gender-traditional understandings of f and mothers' respective parental roles, or instead reflect "real diff\'erence." Based on extensive arc research, this Article demonstrates that an important yet overlooked reason for the developm gender- and marriage-based derivative citizenship law ---jus sanguinis citizenship---was officials' felt to enforce the racially nativist policies that were a core component of American nationality law fo 150 years. The complex interaction of gender, race, family law, and nationality law charted demonstrates that gender-based jus sanguinis citizenship is not a biologically inevitable featu American nationality law, as has been argued, but is in important respects the product of choices m officials engaged in a racially nativist nation-building project. This history also suggests that wha stake in modern challenges to gender-based citizenship laws is not only the constitutionality of t statutes, but a mode of reasoning about citizenship, family, gender, and race that continues to sha practice and politics of citizenship in ways that are often obscured in modern citizenship debates.},
  langid = {english},
  file = {/Users/ana/Zotero/storage/JAMSYXRP/2023_Illegitimate Borders.pdf}
}

