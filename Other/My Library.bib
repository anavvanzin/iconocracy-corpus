@article{costaDiscursoCidadaniaDiferenca2019,
  title = {{O discurso da cidadania e a diferen\c ca de g\^enero}},
  author = {Costa, Pietro},
  year = 2019,
  journal = {RDUno: Revista do Programa de P\'os-Gradua\c c\~ao em Direito da Unochapec\'o},
  volume = {2},
  number = {3},
  pages = {287--308},
  issn = {2596-1438},
  doi = {10.46699/rduno.v2i3.5290},
  urldate = {2023-10-30},
  abstract = {O objetivo do ensaio \'e tra\c car uma hist\'oria de longo respiro sobre o modo como os discursos da cidadania trataram a diferen\c ca de g\^enero na Europa ocidental da Idade M\'edia ao s\'eculo XX, entendendo discursos da cidadania como um mosaico de textos pertencentes a diferentes saberes, mas agrupados pela pretens\~ao de estabelecer uma representa\c c\~ao geral e abstrata do sujeito e da rela\c c\~ao que ele instaura com a comunidade pol\'itica. Nesse sentido, os discursos da cidadania no que diz respeito \`a diferen\c ca de g\^enero podem girar em torno de distintos t\'opicos: hierarquia, corpo e fam\'ilia na Idade M\'edia; igualdade, a partir do jusnaturalismo do s\'eculo XVII, passando por discursos como os de Mary Wollstonecraft e Olympes de Gouges no s\'eculo XVIII; a igualdade ainda \'e importante para o emancipacionismo dos s\'eculos XIX e XX, mas ele valoriza de uma maneira peculiar a identidade de g\^enero. Diferentes maneiras de abordar o campo de tens\~ao entre igualdade e diferen\c ca que tiveram que enfrentar, tamb\'em, discursos que renovavam tradicionais t\'opicos de subalterniza\c c\~ao a partir de novas perspectivas cientificistas e modernizadoras, especialmente no final do s\'eculo XIX e durante os totalitarismos, de modo que somente com segundo p\'os-guerra e com o fim das aventuras `totalit\'arias' \'e que o tema da diferen\c ca feminina volta a ser relacionado com o princ\'ipio da igualdade, que constitui um dos elementos inspiradores das novas democracias constitucionais.},
  copyright = {Copyright (c) 2020 RDUno: Revista do Programa de P\'os-Gradua\c c\~ao em Direito da Unochapec\'o},
  langid = {portuguese},
  keywords = {Controle Social,Gestao Publica,Responsabilidade Fiscal,Transparencia},
  file = {/Users/ana/Zotero/storage/7YIQMN9T/Costa_2019_O discurso da cidadania e a diferença de gênero.pdf}
}

@article{costaOSDIREITOSPARA2022,
  title = {{OS DIREITOS PARA AL\'EM DO ESTADO. A DECLARA\c C\~AO DE 1948 E A SUA RET\'ORICA `UNIVERSALISTA' - DOI: 10.12818/P.0304-2340.2022v81p485}},
  shorttitle = {{OS DIREITOS PARA AL\'EM DO ESTADO. A DECLARA\c C\~AO DE 1948 E A SUA RET\'ORICA `UNIVERSALISTA' - DOI}},
