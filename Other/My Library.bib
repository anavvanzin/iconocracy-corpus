@book{baubockAcquisitionLossNationality|Volume2006,
  title = {Acquisition and {{Loss}} of {{Nationality}}\textbar{{Volume}} 2: {{Country Analyses}}: {{Policies}} and {{Trends}} in 15 {{European Countries}}},
  shorttitle = {Acquisition and {{Loss}} of {{Nationality}}\textbar{{Volume}} 2},
