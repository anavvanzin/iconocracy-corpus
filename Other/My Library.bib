  urldate = {2025-05-15},
  abstract = {A Declara\c c\~ao de 1948 \'e um documento complexo, tanto pela sua g\^enese, como pelo seu conte\'udo. Ainda seria \'util, apesar da ampla literatura dispon\'ivel, uma an\'alise hist\'orica aprofundada, uma investiga\c c\~ao detalhada do processo que conduziu \`a reda\c c\~ao do texto, assim como uma leitura atenta dos seus artigos (das suas conex\~oes e eventuais contradi\c c\~oes ou tens\~oes). No que diz respeito ao primeiro aspecto, em particular, seria necess\'ario n\~ao somente o empenho na ilustra\c c\~ao minuciosa dos `trabalhos preparat\'orios', na investiga\c c\~ao, em suma, da g\^enese imediata do texto, mas, tamb\'em, estender a an\'alise a sua g\^enese remota, reconstruindo as `filosofias' que circulavam nos anos trinta e quarenta na Am\'erica e, mais genericamente, nas comp\'ositas fileiras empenhadas na guerra contra o `totalitarismo' nacional-socialista e fascista.},
  copyright = {Copyright (c) 2023 REVISTA DA FACULDADE DE DIREITO DA UFMG},
  langid = {portuguese},
  file = {/Users/ana/Zotero/storage/CTQU8FWS/Costa e Sontag - 2022 - OS DIREITOS PARA ALÉM DO ESTADO. A DECLARAÇÃO DE 1948 E A SUA RETÓRICA ‘UNIVERSALISTA’ - DOI 10.128.pdf}
}

