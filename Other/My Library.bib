@article{dehartRegulatingMixedMarriages2015,
  title = {Regulating {{Mixed Marriages}} through {{Acquisition}} and {{Loss}} of {{Citizenship}}},
  author = {De Hart, Betty},
  year = 2015,
  journal = {The Annals of the American Academy of Political and Social Science},
  volume = {662},
