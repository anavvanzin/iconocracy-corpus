  keywords = {Agency,American history,Analysis,Civil rights,Contractarianism,Contracts,Dominance,Federal legislation,Females,Gender roles,Male-female relationships,Males,Marriage,Married women,Nineteenth Century,Property Rights,Social aspects,Social conditions,Social history,U.S.A,United States of America,Wives,Women,Womens History},
