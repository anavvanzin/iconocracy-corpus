  author = {Wolodkiewicz, Witold},
  year = 2005,
  journal = {Revue historique de droit fran\c cais et \'etranger (1922-)},
  volume = {83},
  number = {3},
  eprint = {43851606},
  eprinttype = {jstor},
  pages = {441--455},
  publisher = {Editions Dalloz},
  issn = {0035-3280},
  urldate = {2023-01-31},
  abstract = {Dans cet article, tir\'e d'une conf\'erence pr\'esent\'ee \`a la Session consacr\'ee au Code civil des Fran\c cais et tenue \`a Varsovie les 2-3 d\'ecembre 2004 sous les auspices de la Cour Supr\^eme de Pologne, du Tribunal Constitutionnel, de la Facult\'e de Droit et d'Administration de l'Universit\'e de Varsovie et de l'Ambassade de France \`a Varsovie, on se propose de revenir sur les travaux concernant la partie pr\'eliminaire, intitul\'e Livre pr\'eliminaire, du projet du Code civil de l'an VIII, et d'examiner les diff\'erences qui caract\'erisent les trois versions successives du projet. Le premier projet du Livre pr\'eliminaire, pr\'esent\'e par Portalis, comptait quarante et un articles. Il fut influenc\'e par le livre de Domat, Les loix civiles dans leur ordre naturel. Ce premier projet fut contest\'e, d\'ej\`a par des tribunaux d'appels et pendant les travaux au Conseil d'\'etat. Avant de transmettre le projet au Tribun\'at et au Corps l\'egislatif, presque toutes les r\`egles et maximes g\'en\'erales du projet ont \'et\'e \'elimin\'ees comme inutiles et dangereuses dans le texte de la loi. Transform\'e en Titre pr\'eliminaire, le projet du Livre pr\'eliminaire ainsi \'epur\'e comptait seulement huit articles. Ce projet fut rejet\'e par le Corps l\'egislatif. Le projet suivant, pr\'epar\'e par Conseil d'\'etat, ne comptait que six articles. Il fut vot\'e et accept\'e par Corps l\'egislatif le 14 vent\^ose an XI. L'auteur analyse les motifs de ces profonds changements.},
  file = {/Users/anavanzin/Downloads/Bibliografias/Wolodkiewicz_2005_« Livre préliminaire » « titre préliminaire » dans le projet et dans le texte.pdf}
}

