  publisher = {[Sage Publications, Inc., Sage Publications, Ltd.]},
  issn = {0192-5121},
  urldate = {2023-01-30},
  abstract = {This article analyzes the approaches of five democratic countries--France, the United States, Germany, Great Britain, and Israel--to determining membership in the national community. It examines the different definitions of citizenship and the variable uses of ascriptive and functional criteria, the mix of interpretations of jus sanguinis and jus soli, and the evolution of policies of naturalization. It deals with the circumstances surrounding the building of nation and state as explanatory factors, and discusses the implications of transnational and supranational patterns of socioeconomic involvements and entitlements for traditional approaches to citizenship. /// Les notions de citoyennet\'e et de nationalit\'e varient sensiblement d'un pays d\'emocratique \`a un autre et varient aussi selon les \'epoques. L'article \'etudie certaines de ces variations \`a partir des exemples fran\c cais, allemand, anglais, isra\"elien, et \'etatsunien; donc \`a partir de cas d'utilisations diff\'erentes des principes du jus soli et du jus sanguinis selon des traditions nationales bien \'etablies mais en fonction aussi de facteurs d\'emographiques tels que les flux migratoires.},
  file = {/Users/anavanzin/Downloads/Bibliografias/Safran_1997_Citizenship and Nationality in Democratic Systems.pdf}
}

@article{safranStateNationNational1991,
  title = {State, {{Nation}}, {{National Identity}}, and {{Citizenship}}: {{France}} as a {{Test Case}}},
  shorttitle = {State, {{Nation}}, {{National Identity}}, and {{Citizenship}}},
  author = {Safran, William},
  year = 1991,
  journal = {International Political Science Review / Revue internationale de science politique},
  volume = {12},
  number = {3},
  eprint = {1601504},
  eprinttype = {jstor},
  pages = {219--238},
  publisher = {[Sage Publications, Inc., Sage Publications, Ltd.]},
  issn = {0192-5121},
  urldate = {2023-01-31},
  abstract = {Since the Revolution of 1789 membership in the French national community has been based, ideally, on a voluntary commitment to the republic and to political values associated with it. The Jacobin ideal of the "nation state," according to which the nation is a product of the (democratic) state, has not always been adhered to in practice. This paper analyzes the challenges to the Jacobin model posed by the survival of "organic" thinking, the periodic digressions from democratic patterns, the growth of supranationalism, the claims of infranational communities, changes in the elite structure, mass immigration, and other developments. The paper also examines divergent ideological (that is, right and left) approaches to national identity and to the question of accession to French citizenship. /// La r\'evolution fran\c caise de 1789 d\'efinit la communaut\'e nationale \`a partir des notions de volontarisme et d'adh\'esion aux valeurs de la R\'epublique. Or, cet id\'eal ne fut pas toujours respect\'e. L'article analyse les challenges que posent au mod\`ele jacobin des ph\'enom\`enes tels que l'organicisme ethnique, l'apparition d'identit\'es supranationales, et l'affirmation des communaut\'es infranationales; il en r\'esulte de fortes divergences id\'eologiques concernant la notion d'identit\'e nationale et concernant l'acc\`es \`a la citoyennet\'e.},
  file = {/Users/anavanzin/Downloads/Bibliografias/Safran_1991_State, Nation, National Identity, and Citizenship.pdf}
}

@article{sainsburyGenderDifferentiationCitizenship2018,
  title = {Gender Differentiation and Citizenship Acquisition: {{Nationality}} Reforms in Comparative and Historical Perspective},
  shorttitle = {Gender Differentiation and Citizenship Acquisition},
  author = {Sainsbury, Diane},
  year = 2018,
  month = may,
  journal = {Women's Studies International Forum},
  volume = {68},
  pages = {28--35},
  issn = {0277-5395},
  doi = {10.1016/j.wsif.2018.01.005},
  urldate = {2024-04-10},
  abstract = {Feminist scholars have made an impressive contribution to the rethinking of citizenship, but they have largely neglected the gender differentiation of citizenship acquisition. This neglect has resulted in a lack of knowledge concerning the processes of change underpinning nationality reforms that have weakened the patriarchal nature of citizenship. This article seeks to fill the current void through a comparative analysis of nationality reforms that have granted married women an independent right to nationality and mothers the right to transmit their nationality to their children. It examines the politics of these reforms in the United States, France and Germany as well as the international dimension of these nationality reforms. The analysis reveals the long-term significance of the early internationalization of women's nationality rights and the interplay between domestic and transnational feminist activism.},
  keywords = {France,Germany,International feminism,Nationality reforms,United States,Women's movements},
  file = {/Users/ana/Zotero/storage/9SS9AZEM/Sainsbury_2018_Gender differentiation and citizenship acquisition.pdf;/Users/ana/Zotero/storage/AZ48BK7S/S0277539517303163.html}
}

@article{salasCondenaGeneroFemenino2017,
