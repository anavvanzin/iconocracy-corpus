{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/master-record.schema.json",
  "title": "MasterRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "master_record_version",
    "batch_id",
    "item_id",
    "item_hash",
    "input",
    "webscout",
    "iconocode",
    "exports",
    "timestamps"
  ],
  "properties": {
    "master_record_version": { "type": "string" },
    "batch_id": {
      "type": "string",
      "anyOf": [
        { "format": "uuid" },
        { "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[a-z][a-z0-9]*[0-9]+$" }
      ]
    },
    "item_id": { "type": "string", "format": "uuid" },
    "item_hash": { "type": "string", "minLength": 16 },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_url"],
      "properties": {
        "input_url": { "type": "string", "format": "uri" },
        "title_hint": { "type": "string" },
        "date_hint": { "type": "string" },
        "place_hint": { "type": "string" }
      }
    },
    "webscout": { "$ref": "webscout-output.schema.json" },
    "iconocode": { "$ref": "iconocode-output.schema.json" },
    "purificacao": {
      "type": "object",
      "additionalProperties": false,
      "description": "10 ordinal purification indicators (0–3) per codebook",
      "required": [
        "desincorporacao", "rigidez_postural", "dessexualizacao",
        "uniformizacao_facial", "heraldizacao", "enquadramento_arquitetonico",
        "apagamento_narrativo", "monocromatizacao", "serialidade",
        "inscricao_estatal"
      ],
      "properties": {
        "desincorporacao":            { "type": "integer", "minimum": 0, "maximum": 3 },
        "rigidez_postural":           { "type": "integer", "minimum": 0, "maximum": 3 },
        "dessexualizacao":            { "type": "integer", "minimum": 0, "maximum": 3 },
        "uniformizacao_facial":       { "type": "integer", "minimum": 0, "maximum": 3 },
        "heraldizacao":               { "type": "integer", "minimum": 0, "maximum": 3 },
        "enquadramento_arquitetonico":{ "type": "integer", "minimum": 0, "maximum": 3 },
        "apagamento_narrativo":       { "type": "integer", "minimum": 0, "maximum": 3 },
        "monocromatizacao":           { "type": "integer", "minimum": 0, "maximum": 3 },
        "serialidade":                { "type": "integer", "minimum": 0, "maximum": 3 },
        "inscricao_estatal":          { "type": "integer", "minimum": 0, "maximum": 3 },
        "purificacao_composto":       { "type": "number", "minimum": 0, "maximum": 3 },
        "regime_iconocratico": {
          "type": "string",
          "enum": ["fundacional", "normativo", "militar", "contra-alegoria"]
        },
        "coded_by":   { "type": "string" },
        "coded_at":   { "type": "string", "format": "date-time" },
        "notes":      { "type": "string" },
        "confidence_score": { "type": "number", "minimum": 0, "maximum": 1, "description": "Coder confidence (0-1)" },
        "prompt_version":   { "type": "string", "description": "Coding prompt/codebook version" },
        "adjudication_status": { "type": "string", "enum": ["single", "pending", "adjudicated"], "description": "Inter-rater review status" }
      }
    },
    "imes": {
      "type": "object",
      "description": "IMES v3.0 - Iconocracia como Dispositivo Metodológico Estratificado",
      "properties": {
        "version": { "type": "string", "const": "3.0" },
        "regime_visual": {
          "type": "string",
          "description": "Regime Visual identifier (e.g., RV-1: Justitia Monumental)"
        },
        "pathosformel": {
          "type": "string",
          "description": "Dominant Pathosformel/gesto expressivo"
        },
        "linha_de_fuga": {
          "type": "string",
          "description": "Linha de fuga - tensão interna ou transformação em curso"
        },
        "camada_1_atlas": {
          "type": "object",
          "description": "Atlas-Argumento - prancha warburguiana de pertencimento",
          "properties": {
            "prancha_id": { "type": "string" },
            "prancha_titulo": { "type": "string" },
            "status": { "type": "string", "enum": ["preregistrada", "em_construcao", "validada", "rejeitada"] },
            "pares_adjacentes": { "type": "integer" },
            "pares_validos": { "type": "integer" },
            "cjv_satisfeitos": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "camada_2_campo": {
          "type": "object",
          "description": "Campo Cartográfico - mapeamento relacional",
          "properties": {
            "produtor": { "type": "string" },
            "encomenda_institucional": { "type": "string" },
            "circulacao": { "type": "array", "items": { "type": "string" } },
            "posicao_campo": { "type": "string" },
            "transformacao_posicao": { "type": "string" }
          }
        },
        "camada_3_lpai_capta": {
          "type": "object",
          "description": "LPAI-capta - triagem documental (instrumental)",
          "properties": {
            "nivel_pre_iconografico": { "type": "string" },
            "nivel_iconografico": { "type": "string" },
            "nivel_iconologico": { "type": "string" },
            "ausencias": { "type": "array", "items": { "type": "string" } },
            "contradições": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "exports": {
      "type": "object",
      "additionalProperties": false,
      "required": ["abnt_citations", "audit_flags"],
      "properties": {
        "abnt_citations": { "type": "array", "items": { "type": "string" } },
        "audit_flags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at", "updated_at"],
      "properties": {
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
