			<meta property="og:title" content="Alegoria da República"/>
			<meta property="og:description" content="Em primeiro plano, observam-se duas figuras masculinas, uma à esquerda de pé e outra à direita sentada. Ambos portam trajes escuros e carregam folha de papel manuscrita. Acompanham-nos,[...]"/>
			<meta property="og:url" content="https://brasiliana.museus.gov.br/acervos/alegoria-da-republica/"/>
