    <h3>Comments</h3>
    <div id="fiche_comments" class="ck-content"><p>Errors reported by Giovanni Attardi in the book "Variants and errors in the coins of the Italian Republic" second edition 2002/2003:<br><br>1958 surrounding legend ITALIANA REPUBBLICA (Artemide auction no. 3 of 5 September 1996)<br><br>1958 with the flags against the wind on the obverse as in the trial strike of 1957 (<a href="/141785">N# 141785</a> <img src="https://en.numista.com/design/photo.gif" alt="Photo" class="thumbnail_opener" data-thumb-id="141785" data-thumb-country="italie" data-thumb-obverse="5f7c9e89114931.99121707" data-thumb-reverse="5f7c9e88d296a3.22425533" />)<br><br>1966 obverse with vanishing lettering and last ship; without flags on the masts of the other two; and without crosses on the sails.</p></div>
    <script>
        const comment_collapsed_height = 30; // in em
        const $comment_box = $('#fiche_comments');
        if ($comment_box.height() > comment_collapsed_height * 1.20 * 16) {
            $comment_box
                .addClass('collapsed')
                .css('height', comment_collapsed_height + 'em') // defined here rather than in CSS to allow height animation
                .after('<button id="fiche_comments_toggle" class="secondary">Read more</button>');
            $('#fiche_comments_toggle').click(function() {
                if ($comment_box.hasClass('collapsed')) {
                    $comment_box.removeClass('collapsed').css('height', $comment_box.prop('scrollHeight') + 'px');
                    $('#fiche_comments_toggle').text('Show less');
                }
                else {
                    $comment_box.addClass('collapsed').css('height', comment_collapsed_height + 'em');
                    $('#fiche_comments_toggle').text('Read more');
                    // scroll back to the comments only if needed
                    const bottom_of_collapsed_comments = $comment_box.offset().top + comment_collapsed_height * 16;
                    if ($([document.documentElement, document.body]).scrollTop() > bottom_of_collapsed_comments) {
                        $([document.documentElement, document.body]).animate({ scrollTop: bottom_of_collapsed_comments * 0.95 }, 500);
                    }
                }
            });
        }
        else {
            $comment_box.css('position', 'initial') // avoid cropping coin thumbnails
        }
    </script>


