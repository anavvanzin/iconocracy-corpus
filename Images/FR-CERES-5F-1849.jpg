            <script>
            function show_guidelines(article_id) {
                // Create a modal container
                const modal = $('<section class="modal">')
                    .appendTo(document.body);

                // Create an inner container for content and close button
                const modalContainer = $('<div class="modal-container" role="dialog" aria-labelledby="modal_title" aria-modal="true">')
                    .appendTo(modal);

                // Add a close button
                $('<input type="button" class="close" title="Close" value="×">')
                    .click(function() {
                        modal.remove();
                    })
                    .appendTo(modalContainer);

                // Add a header bar for the close button
                $('<header id="modal_title">')
                    .text('Catalog guidelines')
                    .appendTo(modalContainer);

                // Create a content container
                const content = $('<div class="modal-body">')
                    .html('<img src="https://en.numista.com/design/chargement.gif" alt="Loading&hellip;" />')
                    .appendTo(modalContainer);

                // Fetch and display the content
                const url = '/help/article_content.php?id=' + article_id;
                content.load(url, function(response, status) {
                    if (status === 'error') {
                        content.html(`<p>Error: Unable to load the content. Please try again.</p>`);
                    }
                });

                // Close the modal when clicking on the outer grey area
                modal.click(function(e) {
                    if (e.target === modal.get(0)) {
                        modal.remove();
                    }
                });

                // Close the modal when pressing the ESCAPE key
                $(document).keyup(function(e) {
                    if (e.key === "Escape")  modal.remove();
                });
            }
        </script>
