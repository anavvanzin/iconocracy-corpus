<script>
  const seeMoreText = "Ver mais";
  const seeLessText = "Ver menos";

  document.addEventListener("DOMContentLoaded", function () {
    const maxChars = 105;
    const elements = document.querySelectorAll('h1.single-title, .single-title-mobile');

    elements.forEach(el => {
      const fullText = el.textContent.trim();

      if (fullText.length > maxChars) {
        const trimmedText = (() => {
          let cut = fullText.slice(0, maxChars);
          const lastSpace = cut.lastIndexOf(" ");
          return lastSpace > 0 ? cut.slice(0, lastSpace) + '...' : cut + '...';
        })();

        const wrapper = document.createElement('div');
        wrapper.classList.add('title-wrapper');

        const span = document.createElement('span');
        span.textContent = trimmedText;
        span.dataset.fullText = fullText;
        span.dataset.trimmedText = trimmedText;
        span.dataset.expanded = 'false';

        const button = document.createElement('button');
        button.textContent = seeMoreText;
        button.style.marginLeft = '10px';
        button.style.background = 'none';
        button.style.border = 'none';
        button.style.color = '#2b2b2b';
        button.style.cursor = 'pointer';
        button.style.textDecoration = 'underline';
        button.style.fontSize = '1.6rem';

        button.addEventListener('click', function () {
          const expanded = span.dataset.expanded === 'true';

          if (expanded) {
            span.textContent = span.dataset.trimmedText;
            button.textContent = seeMoreText;
            span.dataset.expanded = 'false';
          } else {
            span.textContent = span.dataset.fullText;
            button.textContent = seeLessText;
            span.dataset.expanded = 'true';
          }
        });

        el.textContent = '';
        wrapper.appendChild(span);
        wrapper.appendChild(button);
        el.appendChild(wrapper);
      }
    });
  });
</script>
