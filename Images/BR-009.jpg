<script>
document.addEventListener('DOMContentLoaded', function() {
	const map = {
		'/termosdeuso': '/termsofuse',
		'/termsofuse': '/termosdeuso',
		'/sobreims': '/aboutims',
		'/aboutims': '/sobreims'
	};

	document.querySelectorAll('.header-top__language li a').forEach(link => {
		link.addEventListener('click', function(e) {
			const currentPath = window.location.pathname;
			if (map[currentPath]) {
				e.preventDefault();
				// Pega a URL original do link e troca o pathname
				const url = new URL(this.href);
				url.pathname = map[currentPath];
				window.location.href = url.toString();
			}
		});
	});
});
</script>
	

