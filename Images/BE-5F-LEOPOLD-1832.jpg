        function toggleMenu(menuName) {
            let button = document.getElementById(menuName+"_button");
            let pressed = button.getAttribute("aria-pressed")==="true";
            button.setAttribute("aria-pressed", pressed? "false": "true");
            document.getElementById(menuName).setAttribute("aria-hidden", pressed? "true": "false");
            let links = document.getElementById(menuName).getElementsByTagName("a");
            for (let i=0; i<links.length; i++) {
                links[i].setAttribute("tabindex", pressed? "-1": "0");
            }
            let buttons = document.getElementById(menuName).getElementsByTagName("button");
            for (let i=0; i<buttons.length; i++) {
                buttons[i].setAttribute("tabindex", pressed? "-1": "0");
            }
            let selects = document.getElementById(menuName).getElementsByTagName("select");
            for (let i=0; i<selects.length; i++) {
                selects[i].setAttribute("tabindex", pressed? "-1": "0");
            }
            if (selects.length>0) activate_select2();            let inputs = document.getElementById(menuName).getElementsByTagName("input");
            for (let i=0; i<inputs.length; i++) {
                inputs[i].setAttribute("tabindex", pressed? "-1": "0");
            }
            if (menuName==="account_menu" && (!pressed)) {
                if (document.getElementById("language_menu_button").getAttribute("aria-pressed")==="true") toggleMenu("language_menu");
                if (document.getElementById("search_menu_button").getAttribute("aria-pressed")==="true") toggleMenu("search_menu");
            }
            else if (menuName==="search_menu" && (!pressed)) {
                document.getElementById("search_menu_input").focus();
                if (document.getElementById("language_menu_button").getAttribute("aria-pressed")==="true") toggleMenu("language_menu");
                if (document.getElementById("account_menu_button").getAttribute("aria-pressed")==="true") toggleMenu("account_menu");
            }
            else if (menuName.substring(0, 9)==="forum_cat") {
                if (!pressed) {
                    document.cookie =  menuName + '=; expires=Thu, 01 Jan 1970 00:00:00 UTC';
                }
                else {
                    let date = new Date(Date.now() + 365 * 24 * 3600 * 1000);
                    document.cookie = menuName + '=1; expires=' + date.toUTCString();
                }
            }
        }

        function togglePinnedAccountMenu() {
            let pinned = document.getElementById("global_header").className==="pinned_account";
            if (!pinned) {
                document.cookie = "pinned_account_menu=1; expires=Sunday, 13-Apr-2036 17:04:31 CEST; domain=numista.com; path=/";
                document.getElementById("global_header").className = "pinned_account";
                document.getElementById("pinned_account_button").src = "https://en.numista.com/design/wrap.svg";
                document.getElementById("pinned_account_button").alt = "Wrap";
                document.getElementById("pinned_account_button").title = "Wrap";
                if (window.matchMedia("(max-width: 600px)").matches) toggleMenu("account_menu");
            }
            else {
                document.cookie = "pinned_account_menu=0; expires=Thu, 01 Jan 1970 00:00:00 UTC; domain=numista.com; path=/";
                document.getElementById("global_header").className = "";
                document.getElementById("pinned_account_button").src = "https://en.numista.com/design/pin.svg";
                document.getElementById("pinned_account_button").alt = "Pin";
                document.getElementById("pinned_account_button").title = "Pin";
                if (document.getElementById("account_menu").getAttribute("aria-hidden")!=="true") toggleMenu("account_menu");
            }
        }

        /* Matomo */
        let _paq = window._paq = window._paq || [];
        _paq.push(['setCustomDimension', 1, 'no']);
        _paq.push(["setCookieDomain", "*.numista.com"]);
        _paq.push(["setDomains", ["*.numista.com"]]);
        _paq.push(['trackPageView', null, {
            dimension2: 'en',
            dimension4: 'en',
            dimension5: 'numiscorner'
        }]);
        _paq.push(['enableLinkTracking']);
        _paq.push(['trackAllContentImpressions']);
        (function() {
            let u="https://analytics.numista.com/";
            _paq.push(['setTrackerUrl', u+'matomo.php']);
            _paq.push(['setSiteId', '10']);
            let d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
            g.type='text/javascript'; g.async=true; g.src=u+'matomo.js'; s.parentNode.insertBefore(g,s);
        })();
    </script>

