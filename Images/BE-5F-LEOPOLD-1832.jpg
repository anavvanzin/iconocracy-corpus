<section id="fiche_descriptions">

    
    
    <h3>Obverse</h3>
    
        <p>Head of King Leopold I of Belgium facing left, with sideburns, wearing an oak wreath tied with a ribbon behind. Legend in French.</p>
        
        <p>
        <strong>Script:</strong>
        Latin    </p>
        
        <p>
        <strong>Lettering:</strong>
        <br />        <span id="obverse_lettering" class="lettering">LEOPOLD PREMIER ROI DES BELGES  <br />
BRAEMT F.</span>
    </p>
            
        <p>
        <strong>Unabridged legend:</strong>
                Braemt fecit    </p>
        
        <p>
        <strong>Translation:</strong>
        <br />        Leopold the First, King of the Belgians<br />
Made by Braemt    </p>
        
        <p>
        <strong>Engraver:</strong>
        <a href="https://en.numista.com/catalogue/artist.php?id=160">Joseph-Pierre Braemt</a>    </p>
        
    
    <h3>Reverse</h3>
    
        <p>Inscription in three lines. Five-pointed star below. Oak wreath around with leaves and acorns.</p>
        
        <p>
        <strong>Script:</strong>
        Latin    </p>
        
        <p>
        <strong>Lettering:</strong>
        <br />        <span id="reverse_lettering" class="lettering">5<br />
FRANCS<br />
1832<br />
★</span>
    </p>
            
        
        
        <p>
        <strong>Engraver:</strong>
        <a href="https://en.numista.com/catalogue/artist.php?id=160">Joseph-Pierre Braemt</a>    </p>
        
    
    <h3>Edge</h3>
    
        <p>Incuse 1832-1844) or raised (1847-1849) lettered plain edge</p>
        
        <p>
        <strong>Script:</strong>
        Latin    </p>
        
        <p>
        <strong>Lettering:</strong>
        <span id="edge_lettering" class="lettering">DIEU PROTÈGE LA BELGIQUE *</span>
    </p>
        
        
        <p>
        <strong>Translation:</strong>
                God Protects Belgium    </p>
    
    


    <h3>Mint</h3>
    <a href="mint.php?id=1338">Royal Mint of Belgium</a>, Brussels, Belgium (983-2017)

    <h3>Comments</h3>
    <div id="fiche_comments" class="ck-content">Position A: The edge lettering reads in upright position when the reverse side (with face value) faces up.<br />
Position B: The edge lettering reads in upright position when the obverse side (with head) faces up.</div>
    <script>
        const comment_collapsed_height = 30; // in em
        const $comment_box = $('#fiche_comments');
        if ($comment_box.height() > comment_collapsed_height * 1.20 * 16) {
            $comment_box
                .addClass('collapsed')
                .css('height', comment_collapsed_height + 'em') // defined here rather than in CSS to allow height animation
                .after('<button id="fiche_comments_toggle" class="secondary">Read more</button>');
            $('#fiche_comments_toggle').click(function() {
                if ($comment_box.hasClass('collapsed')) {
                    $comment_box.removeClass('collapsed').css('height', $comment_box.prop('scrollHeight') + 'px');
                    $('#fiche_comments_toggle').text('Show less');
                }
                else {
                    $comment_box.addClass('collapsed').css('height', comment_collapsed_height + 'em');
                    $('#fiche_comments_toggle').text('Read more');
                    // scroll back to the comments only if needed
                    const bottom_of_collapsed_comments = $comment_box.offset().top + comment_collapsed_height * 16;
                    if ($([document.documentElement, document.body]).scrollTop() > bottom_of_collapsed_comments) {
                        $([document.documentElement, document.body]).animate({ scrollTop: bottom_of_collapsed_comments * 0.95 }, 500);
                    }
                }
            });
        }
        else {
            $comment_box.css('position', 'initial') // avoid cropping coin thumbnails
        }
    </script>


    <h3>See also</h3>
    
