                <script>
                    $(function() {
                        const literatureType = "";
                        let salesPlaceholder = "See %s sale offers";
                        const showGreysheet = "1";
                        $.get("/catalogue/buy_coin.php", {id: "8472", literature_type: ""})
                            .done(function(response) {
                                if(response.length>2) {
                                    let responses = response.split("=*=*=*= SEPARATOR =*=*=*=");
                                    $("#sale_offers").html(responses[0]).css("display", "block");
                                    if (literatureType === "")
                                        $("#ebay_coins").html(responses[1]);
                                    $("#pub_space").addClass("ebay").css("min-height", $("#ebay_coins").height());
                                                                       
                                    if (responses[2] && parseInt(responses[2].trim(), 10) > 1)  {
                                        $("#see_available_sales").css("display", "");
                                        $("#see_available_sales span").text(salesPlaceholder.replace(`%s`, responses[2]));
                                    }
                                }
                            });
                        if (showGreysheet) 
                            $.get("/catalogue/buy_coin.php", {id: "8472", type: "greysheet"})
                            .done(function(response) {
                                if(response.length>2) {
                                    let responses = response.split("=*=*=*= SEPARATOR =*=*=*=");
                                    $("#sale_offers_greysheet").html(responses[0]).css("display", "block");
                                    $("#ebay_coins").html(responses[1]);
                                    $("#pub_space").addClass("ebay").css("min-height", $("#ebay_coins").height())
                                }
                            });
                    });
                </script>
