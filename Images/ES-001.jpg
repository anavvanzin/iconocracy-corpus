                <div class="field is-grouped is-grouped-multiline is-grouped-centered is-align-items-center ">
        <div class="control">
        <label title="La consulta que, en BD, restringe la búsqueda a los títulos en acceso libre">
            <input type="checkbox" class="checkbox" name="g" value="fa" >
            Solo en títulos de acceso libre
        </label>
    </div>

    </div>

                <div class="field is-grouped is-grouped-multiline is-grouped-centered is-align-items-center is-hidden">
