    <script type="text/javascript">

        function swapQueryRows() {
            var os = document.form.o,
                ws = document.form.w,
                fs = document.form.f,
                f,
                src,
                dst;

            if (fs[0].type === "select-one") {
                var options = fs[0].options,
                    length = options.length;
                for (var i = 0; i < length; i += 1) {
                    if (i === 0 || options[i].defaultSelected) {
                        f = options[i].value;
                        break;
                    }
                }
            }

            function clear(start) {
                os[start].value = "";
                ws[start].value = "";
                if (f !== undefined) {
                    fs[start].value = f;
                }
            }
            
            function isDefault(start) {
                if (
                    os[start].value !== ""
                    || ws[start].value !== ""
                    || (f !== undefined && fs[start].value !== f)
                ) {
                    return false;
                }
                return true;
            }
            
            function copy(src, dst) {
                os[dst].value = os[src].value;
                ws[dst].value = ws[src].value;
                fs[dst].value = fs[src].value;
            }
            
            if (window.innerWidth <= 768) {
                src = 0;
                dst = 1;
            } else {
                src = 1;
                dst = 0;
            }
            if (!isDefault(src) && isDefault(dst)) {
                copy(src, dst);
            }
            clear(src);
        }

        window.addEventListener("pagehide", function () {
           __.saveForm("bd-simple-form", document.form);
        });

        window.addEventListener("pageshow", function () {
            __.loadForm("bd-simple-form", document.form);
            swapQueryRows();
        });
        
        window.addEventListener("resize", swapQueryRows);
    </script>

