{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iconocracia.dev/schemas/research-cluster.schema.json",
  "title": "ResearchClusterDoc",
  "description": "Workflow doc defining N thematic research clusters (topic × prompts × typed extraction schema). Consumed by tools/scripts/run_research_cluster.py to orchestrate Semantic Scholar + OpenAlex + Zotero cascade and write Obsidian vault notes.",
  "type": "object",
  "additionalProperties": false,
  "required": ["workflow_name", "version", "clusters", "destinos"],
  "properties": {
    "workflow_name": {
      "type": "string",
      "minLength": 1,
      "description": "Slug-safe name (e.g. elicit-iconocracia-2026)"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Semver MAJOR.MINOR of this workflow doc"
    },
    "criado": {
      "type": "string",
      "format": "date",
      "description": "ISO YYYY-MM-DD"
    },
    "autor": { "type": "string" },
    "descricao": { "type": "string" },
    "filtros_globais": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "anos": {
          "type": "array",
          "items": { "type": "integer" },
          "minItems": 2,
          "maxItems": 2,
          "description": "[min, max] inclusive"
        },
        "linguas": {
          "type": "array",
          "items": { "type": "string", "enum": ["en", "fr", "de", "pt", "es", "it", "la"] }
        },
        "tipos": {
          "type": "array",
          "items": { "type": "string", "enum": ["journal_article", "book_chapter", "book", "thesis", "conference_paper", "report"] }
        },
        "disciplinary_filter": {
          "type": "string",
          "description": "Prompt classifier aplicado pós-busca (e.g. 'jurídico-penal: aceitar só legal history / criminal law; rejeitar antropologia pura / história da arte pura')"
        }
      }
    },
    "tool": {
      "type": "string",
      "enum": ["native-cascade", "elicit-browser", "perplexity", "zotero-only"],
      "default": "native-cascade",
      "description": "Fonte primária. native-cascade = Semantic Scholar -> OpenAlex -> Zotero local."
    },
    "clusters": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/cluster" }
    },
    "destinos": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vault_root"],
      "properties": {
        "vault_root": {
          "type": "string",
          "description": "Path relativo do hub, ex: vault/pesquisa/{workflow_name}/"
        },
        "papers_subdir": { "type": "string", "default": "papers/" },
        "generated_subdir": {
          "type": "string",
          "default": "_generated/",
          "description": "Regeneráveis (gitignored). Sumários, CSVs. NUNCA sobrescreve notas autorais."
        },
        "csv_export": {
          "type": "string",
          "description": "Path relativo p/ CSV tabela-longa, opcional"
        }
      }
    },
    "sessoes": {
      "type": "array",
      "description": "Agrupamento sugerido para execução humana-in-loop",
      "items": {
        "type": "object",
        "required": ["n", "eixos"],
        "properties": {
          "n": { "type": "integer", "minimum": 1 },
          "eixos": { "type": "array", "items": { "type": "integer" } },
          "tempo_min": { "type": "integer" }
        }
      }
    }
  },
  "$defs": {
    "cluster": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "slug", "titulo", "prioridade", "prompts", "extraction_schema"],
      "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "description": "kebab-case, usado em nomes de pasta/arquivo"
        },
        "titulo": { "type": "string", "minLength": 1 },
        "prioridade": {
          "type": "string",
          "enum": ["alta", "media", "baixa", "complementar"]
        },
        "descricao": { "type": "string" },
        "prompts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "texto"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "pattern": "^\\d+\\.\\d+$", "description": "ex: 1.1, 1.2" },
              "texto": { "type": "string", "minLength": 10 },
              "peso": { "type": "number", "minimum": 0, "maximum": 1, "default": 1.0 }
            }
          }
        },
        "buscas_extras": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "query": { "type": "string" },
              "autores": { "type": "array", "items": { "type": "string" } },
              "lingua": { "type": "string" }
            }
          }
        },
        "limite_papers": {
          "type": "integer",
          "minimum": 1,
          "maximum": 500,
          "default": 50,
          "description": "Corte pós-ranking antes da extração (custo Claude)"
        },
        "extraction_schema": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["nome", "tipo", "instrucao"],
            "additionalProperties": false,
            "properties": {
              "nome": { "type": "string", "minLength": 1 },
              "tipo": {
                "type": "string",
                "enum": ["texto_curto", "texto_longo", "sim_nao", "alta_media_baixa", "inteiro", "lista", "ano"]
              },
              "instrucao": {
                "type": "string",
                "minLength": 10,
                "description": "Pergunta em EN dirigida ao extractor. DEVE terminar com regra: 'If the abstract does not contain this information, return NULL.'"
              },
              "required_when_available": {
                "type": "boolean",
                "default": true
              }
            }
          }
        },
        "tags_vault": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tags Obsidian aplicadas em cada nota-paper deste cluster (ex: pesquisa/eixo-1, metodo/rechtsikonographie)"
        }
      }
    }
  }
}
